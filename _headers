/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https://media.obreko.com https://images.unsplash.com; media-src 'self' https://media.obreko.com; connect-src 'self' https://api.emailjs.com; frame-ancestors 'none'; upgrade-insecure-requests

/propuestas/*
  X-Robots-Tag: noindex, nofollow, noarchive

/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/sitemap.xml
  Content-Type: text/xml; charset=utf-8
  Cache-Control: public, max-age=86400

/robots.txt
  Cache-Control: public, max-age=86400

/*.css
  Cache-Control: no-cache, must-revalidate

/*.js
  Cache-Control: no-cache, must-revalidate

/js/*
  Cache-Control: no-cache, no-store, must-revalidate

/*.svg
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  Cache-Control: public, max-age=31536000, immutable

/**/*.webp
  Cache-Control: public, max-age=31536000, immutable

/**/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/**/*.woff2
  Cache-Control: public, max-age=31536000, immutable
